<?xml version="1.0" encoding="windows-1252"?>
<!--
  Diagram Kelas - Sistem ATS Azra Hospital (ats-v2).
  Format XMI 2.1 (UML 2.1) untuk impor ke Sparx Enterprise Architect 15.2.
  Impor: Project Browser > klik kanan paket tujuan > Import/Export > Import Package from XMI.
  Atribut = field bisnis (FK & timestamp disembunyikan; relasi diwakili garis).
  Komposisi = diamond terisi (sub-record yang hidup-mati bergantung induk).
  Garis tanpa angka multiplicity sesuai permintaan. Operasi = method domain nyata.
  Untuk diagram Overview: pilih semua > klik kanan > Suppress Attributes/Operations.
-->
<xmi:XMI xmi:version="2.1"
         xmlns:uml="http://schema.omg.org/spec/UML/2.1"
